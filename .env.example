# ============================================================
# Pokemon ETL — Variables de Entorno
# Copia este archivo a .env y ajusta los valores.
# La PokéAPI es pública: NO requiere API key.
# ============================================================

# --- Extracción ---
# Número de Pokémon a procesar (151 = Gen 1, 251 = Gen 1+2, 898 = todos)
POKEMON_LIMIT=151

# Segundos de espera entre requests consecutivos (respetar rate limit)
REQUEST_DELAY=0.3

# Número de reintentos si un request falla
MAX_RETRIES=3

# --- Logging ---
# Niveles: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Rutas de datos (relativas al proyecto) ---
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_OUTPUT_DIR=data/output
LOGS_DIR=logs
